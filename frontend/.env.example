# Axiom OS — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
#   1. Copy this file:  cp .env.example .env.local
#   2. Fill in your values below
#   3. Restart the dev server:  npm run dev
#
# VERCEL DEPLOYMENT
#   Add all non-commented keys to:
#   Vercel Dashboard → Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# === Supabase (Required — cloud data sync) ====================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === Maps & GIS (Required for SiteMap 3D layer) ===============================
# Get your token at: https://account.mapbox.com/access-tokens/
# Scope required: styles:read, tiles:read
# Without this, the SiteMap component will render a graceful "Engine Standby"
# placeholder — no crash occurs.
VITE_MAPBOX_TOKEN=pk.eyJ1IjoiWU9VUl9VU0VSTkFNRSIsImEiOiJZT1VSX1RPS0VOIn0.PLACEHOLDER

# === AI / LLM Keys (Optional — can also be set inside the app Settings UI) ===
# App-level localStorage settings take priority over these env vars.
#
# VITE_ANTHROPIC_KEY=sk-ant-...
# VITE_OPENAI_KEY=sk-...
# VITE_GROQ_KEY=gsk_...
# VITE_TOGETHER_KEY=tog_...
